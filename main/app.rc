    VALUE "ProductVersion",  APP_VERSION
    VALUE "ProductName", "MusicPlayer"
    VALUE "LegalCopyright",  "Copyright (C) 2026 AliceCartelet"
    END
        END
    BLOCK "VarFileInfo"
    BEGIN
